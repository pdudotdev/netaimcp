t6\",\n      \"source_ip\": \"10.0.0.25\",\n      \"destination_device\": \"IBN\",\n      \"destination_ip\": \"200.50.50.6\",\n      \"ecmp\": true,\n      \"ecmp_node\": \"C1C\",\n      \"ecmp_next_hops\": [\"E1C\", \"E2C\"],\n      \"egress_devices\": [\"E1C\", \"E2C\"],\n      \"scope_devices\": [\"C1C\", \"C2C\", \"E1C\", \"E2C\", \"IBN\"]\n    },\n    {\n      \"id\": \"C2C_TO_IAN\",\n      \"description\": \"C2C (ABR, Cisco c8000v) via OSPF Area 0 to E1C/E2C ASBRs (ECMP) then BGP to ISP A IAN\",\n      \"source_device\": \"C2C\",\n      \"source_interface\": \"GigabitEthernet5\",\n      \"source_ip\": \"10.0.0.33\",\n      \"destination_device\": \"IAN\",\n      \"destination_ip\": \"200.40.40.2\",\n      \"ecmp\": true,\n      \"ecmp_node\": \"C2C\",\n      \"ecmp_next_hops\": [\"E1C\", \"E2C\"],\n      \"egress_devices\": [\"E1C\", \"E2C\"],\n      \"scope_devices\": [\"C2C\", \"C1C\", \"E1C\", \"E2C\", \"IAN\"]\n    },\n    {\n      \"id\": \"E1C_TO_E2C\",\n      \"description\": \"E1C via OSPF Area 0 core (C1C and C2C ECMP) to E2C\",\n      \"source_device\": \"E1C\",\n      \"source_interface\": \"GigabitEthernet2\",\n      \"source_ip\": \"10.0.0.26\",\n      \"destination_device\": \"E2C\",\n      \"destination_ip\": \"10.0.0.38\",\n      \"ecmp\": true,\n      \"ecmp_node\": \"E1C\",\n      \"ecmp_next_hops\": [\"C1C\", \"C2C\"],\n      \"egress_devices\": [\"C1C\", \"C2C\"],\n      \"scope_devices\": [\"E1C\", \"C1C\", \"C2C\", \"E2C\"]\n    },\n    {\n      \"id\": \"A1C_TO_X1C\",\n      \"description\": \"A1C (Area 1 stub) primary via C1C ABR (OSPF cost 5), backup via C2C (cost 10), through OSPF Area 0 to E1C/E2C, BGP via ISP A IAN, to remote site X1C\",\n      \"source_device\": \"A1C\",\n      \"source_interface\": \"Loopback0\",\n      \"source_ip\": \"192.168.11.1\",\n      \"destination_device\": \"X1C\",\n      \"destination_ip\": \"200.40.8.1\",\n      \"ecmp\": false,\n      \"primary_abr\": \"C1C\",\n      \"scope_devices\": [\"A1C\", \"C1C\", \"C2C\", \"E1C\", \"E2C\", \"IAN\", \"X1C\"]\n    },\n    {\n      \"id\": \"A2C_TO_X1C\",\n      \"description\": \"A2C (Area 1 stub) primary via C2C ABR (OSPF cost 5), backup via C1C (cost 10), through OSPF Area 0 to E1C/E2C, BGP via ISP B IBN, to remote site X1C\",\n      \"source_device\": \"A2C\",\n      \"source_interface\": \"Loopback0\",\n      \"source_ip\": \"192.168.22.1\",\n      \"destination_device\": \"X1C\",\n      \"destination_ip\": \"200.50.8.1\",\n      \"ecmp\": false,\n      \"primary_abr\": \"C2C\",\n      \"scope_devices\": [\"A2C\", \"C1C\", \"C2C\", \"E1C\", \"E2C\", \"IBN\", \"X1C\"]\n    }\n  ]\n}\n","numLines":71,"startLine":1,"totalLines":71}}}
